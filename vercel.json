{
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist/client",
  "installCommand": "npm ci && npm --prefix frontend ci --legacy-peer-deps",
  "framework": "vite",
  "functions": {
    "api/index.py": { "maxDuration": 300 },
    "api/index-dispatch.ts": { "maxDuration": 300 }
  },
  "rewrites": [
    {
      "source": "/api/v1/documents/upload/direct",
      "destination": "/api/blob-upload"
    },
    {
      "source": "/api/v1/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
