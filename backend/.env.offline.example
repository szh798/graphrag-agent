# Offline interview demo defaults.
# Copy to backend/.env only when you want to run the UI, KG browsing, search,
# health checks, and existing indexed-data demo without cloud credentials.

LLM_PROVIDER=offline-demo
LLM_API_KEY=
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_MODEL=local-model
LLM_INDEX_MODEL=local-model
LLM_EMBEDDING_MODEL=local-embedding
LLM_EMBEDDING_DIMENSIONS=1024
LLM_TEMPERATURE=0.1

GRAPHRAG_GRAPH_BACKEND=filesystem
GRAPHRAG_STORAGE_BACKEND=filesystem
GRAPHRAG_APP_BACKEND=filesystem
GRAPHRAG_BLOB_BACKEND=filesystem
GRAPHRAG_QUEUE_BACKEND=local_thread
GRAPHRAG_ENABLE_EMBEDDINGS=false
GRAPHRAG_ENABLE_VECTOR_RETRIEVAL=false
GRAPHRAG_DATA_DIR=backend/data

# Force lightweight local parsing for the offline demo package.
# Supports selectable-text PDF, HTML, TXT, Markdown. Scanned PDFs/images need OCR or MinerU.
PARSER_MODE=local

MINERU_API_TOKEN=
MINERU_BASE_URL=https://mineru.net/api/v4
MINERU_MODEL_VERSION=pipeline
MINERU_POLL_INTERVAL_SECONDS=5
MINERU_MAX_POLLS=120
MINERU_DOWNLOAD_RETRIES=3
