# HTTP perimeter
# Production: set a long random value in both the backend and trusted site
# proxy, then set REQUIRE_PROXY_AUTH=true. Leave blank for direct local dev.
BACKEND_PROXY_SECRET=
REQUIRE_PROXY_AUTH=false
# Comma-separated browser origins. A wildcard, if explicitly configured, is
# always credential-free; the default is the local frontend on port 5173.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ENVIRONMENT=development

# Formal accounts and organization tenants (Clerk OIDC/JWT)
# The issuer/JWKS URL can be derived from the publishable key. Authorized
# parties must contain every browser origin allowed to present a session.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_ISSUER=https://your-instance.clerk.accounts.dev
CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
CLERK_AUTHORIZED_PARTIES=http://localhost:5173,https://your-public-site.example
# CLERK_AUDIENCE=your_optional_jwt_audience

# LLM API (OpenAI-compatible; required for entity extraction + QA)
LLM_PROVIDER=zhipu
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# QA/conversation model
LLM_MODEL=glm-5.2
LLM_INPUT_CNY_PER_1M_TOKENS=8
LLM_OUTPUT_CNY_PER_1M_TOKENS=28
# Lightweight model used only during indexing/entity extraction
LLM_INDEX_MODEL=glm-4-flash-250414
LLM_EMBEDDING_MODEL=embedding-3
LLM_EMBEDDING_DIMENSIONS=1024
LLM_TEMPERATURE=0.1
# Used only for account cost accounting; these values do not limit tokens.
LLM_INPUT_USD_PER_1M_TOKENS=0
LLM_OUTPUT_USD_PER_1M_TOKENS=0

# Optional error alert destination. Aggregated events remain available in the
# operations dashboard even when no webhook is configured.
OPS_ALERT_WEBHOOK_URL=
# auto detects Feishu/Lark URLs; use generic for a receiver that accepts the
# privacy-safe event JSON documented in docs/operations-runbook.md.
OPS_ALERT_WEBHOOK_PROVIDER=auto
# Set only after verifying the cloud provider's point-in-time restore policy.
DATABASE_PITR_ENABLED=false
DATABASE_BACKUP_RETENTION_HOURS=0

# Storage
# filesystem = local JSON/files. Good for local development and demos.
# On Vercel, set GRAPHRAG_DATA_DIR=/tmp/graphrag-data only for prototypes;
# production should replace this with database/object storage adapters.
GRAPHRAG_STORAGE_BACKEND=filesystem
GRAPHRAG_DATA_DIR=backend/data
GRAPHRAG_APP_BACKEND=filesystem
GRAPHRAG_BLOB_BACKEND=filesystem
GRAPHRAG_QUEUE_BACKEND=local_thread
GRAPHRAG_ENABLE_EMBEDDINGS=auto
GRAPHRAG_ENABLE_VECTOR_RETRIEVAL=auto
GRAPHRAG_REQUIRE_EMBEDDINGS=false
INDEX_QUEUE_KEY=graphrag:index:queue
INDEX_PROCESSING_KEY=graphrag:index:queue:processing
INDEX_JOB_LEASE_SECONDS=330
INDEX_JOB_MAX_RECOVERIES=2
INDEX_OWNER_LOCK_SECONDS=660
# The long-running Railway Worker refreshes this Upstash record in a separate
# thread, including while an indexing job is running. The public gateway treats
# a missing, malformed, expired, or version-mismatched heartbeat as not ready.
INDEX_WORKER_HEARTBEAT_KEY=graphrag:index:queue:worker-heartbeat
INDEX_WORKER_HEARTBEAT_TTL_SECONDS=120
INDEX_WORKER_HEARTBEAT_INTERVAL_SECONDS=40
# Optional stable replica label. When omitted Railway's replica ID is used;
# local development generates a random ID and never derives it from the PID.
INDEX_WORKER_ID=
# Vercel wakes its dispatcher after Blob callbacks; Railway polls continuously.
INDEX_WORKER_MODE=vercel
# Shared only by Vercel and the scheduled GitHub Actions dispatcher.
INDEX_DISPATCH_SECRET=

# Graph database
# filesystem = read/write backend/data/kg JSON files
# neo4j = use Neo4j AuraDB for Entity/Chunk/Document graph + vector indexes
GRAPHRAG_GRAPH_BACKEND=filesystem
NEO4J_URI=neo4j+s://your-aura-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DATABASE=neo4j
NEO4J_VECTOR_DIMENSIONS=1024

# Industrial production adapters.
# Set these backends in production:
# GRAPHRAG_APP_BACKEND=postgres
# GRAPHRAG_BLOB_BACKEND=vercel_blob
# GRAPHRAG_QUEUE_BACKEND=upstash
DATABASE_URL=postgresql://user:password@host/dbname
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here
BLOB_ACCESS=private
UPSTASH_REDIS_REST_URL=https://your-upstash-url
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# Optional permanent second engine. The public Vercel gateway only receives
# these service-boundary settings; Neo4j/Neon credentials belong exclusively
# to the private Railway API/worker environment (see deploy/lightrag/env.example).
LIGHTRAG_ENABLED=false
LIGHTRAG_VERSION=1.5.4
LIGHTRAG_STRICT_VERSION=true
LIGHTRAG_TRANSPORT=remote
LIGHTRAG_BASE_URL=https://your-private-lightrag-service.example
# Generate two independent random secrets of at least 32 bytes. The workspace
# secret must match Railway but is never exposed to the browser.
LIGHTRAG_HMAC_SECRET=replace_with_32_byte_random_secret
LIGHTRAG_WORKSPACE_SECRET=replace_with_different_32_byte_random_secret
LIGHTRAG_HMAC_MAX_AGE_SECONDS=300
LIGHTRAG_REQUIRE_DISTRIBUTED_NONCE=true
LIGHTRAG_NONCE_REDIS_REST_URL=https://your-upstash-url
LIGHTRAG_NONCE_REDIS_REST_TOKEN=your_upstash_token_here
LIGHTRAG_NONCE_KEY_PREFIX=graphrag:lightrag:nonce
LIGHTRAG_NONCE_TIMEOUT_SECONDS=5
LIGHTRAG_TIMEOUT_SECONDS=300
LIGHTRAG_DEFAULT_MODE=mix
LIGHTRAG_MAX_GRAPH_NODES=200
LIGHTRAG_MAX_GRAPH_EDGES=2000
LIGHTRAG_EXPORT_MAX_NODES=10000
LIGHTRAG_EXPORT_MAX_EDGES=100000
LIGHTRAG_BACKFILL_ON_START=false
LIGHTRAG_BACKFILL_ALL_TENANTS_ACK=
LIGHTRAG_BACKFILL_RELEASE_ID=initial-v1
LIGHTRAG_BACKFILL_BATCH_SIZE=25
LIGHTRAG_BACKFILL_INTERVAL_SECONDS=300
LIGHTRAG_BACKFILL_INCLUDE_FAILED=false
LIGHTRAG_BACKFILL_FORCE=false

# Document parser mode:
# auto  = use MinerU when MINERU_API_TOKEN exists, otherwise use lightweight local parser
# local = force local parser for selectable-text PDF/HTML/TXT/Markdown
# mineru = force MinerU cloud parser
PARSER_MODE=auto

# MinerU cloud API (required for document parsing)
MINERU_API_TOKEN=your_mineru_api_token_here
MINERU_BASE_URL=https://mineru.net/api/v4
MINERU_MODEL_VERSION=pipeline
MINERU_POLL_INTERVAL_SECONDS=5
MINERU_MAX_POLLS=120
MINERU_DOWNLOAD_RETRIES=3
