# HTTP perimeter
# Production: set a long random value in both the backend and trusted site
# proxy, then set REQUIRE_PROXY_AUTH=true. Leave blank for direct local dev.
BACKEND_PROXY_SECRET=
REQUIRE_PROXY_AUTH=false
# Comma-separated browser origins. A wildcard, if explicitly configured, is
# always credential-free; the default is the local frontend on port 5173.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ENVIRONMENT=development

# LLM API (OpenAI-compatible; required for entity extraction + QA)
LLM_PROVIDER=zhipu
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# QA/conversation model
LLM_MODEL=glm-5.2
# Lightweight model used only during indexing/entity extraction
LLM_INDEX_MODEL=glm-4-flash-250414
LLM_EMBEDDING_MODEL=embedding-3
LLM_EMBEDDING_DIMENSIONS=1024
LLM_TEMPERATURE=0.1

# Storage
# filesystem = local JSON/files. Good for local development and demos.
# On Vercel, set GRAPHRAG_DATA_DIR=/tmp/graphrag-data only for prototypes;
# production should replace this with database/object storage adapters.
GRAPHRAG_STORAGE_BACKEND=filesystem
GRAPHRAG_DATA_DIR=backend/data
GRAPHRAG_APP_BACKEND=filesystem
GRAPHRAG_BLOB_BACKEND=filesystem
GRAPHRAG_QUEUE_BACKEND=local_thread
GRAPHRAG_ENABLE_EMBEDDINGS=auto
GRAPHRAG_ENABLE_VECTOR_RETRIEVAL=auto
GRAPHRAG_REQUIRE_EMBEDDINGS=false
INDEX_QUEUE_KEY=graphrag:index:queue

# Graph database
# filesystem = read/write backend/data/kg JSON files
# neo4j = use Neo4j AuraDB for Entity/Chunk/Document graph + vector indexes
GRAPHRAG_GRAPH_BACKEND=filesystem
NEO4J_URI=neo4j+s://your-aura-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DATABASE=neo4j
NEO4J_VECTOR_DIMENSIONS=1024

# Industrial production adapters.
# Set these backends in production:
# GRAPHRAG_APP_BACKEND=postgres
# GRAPHRAG_BLOB_BACKEND=vercel_blob
# GRAPHRAG_QUEUE_BACKEND=upstash
DATABASE_URL=postgresql://user:password@host/dbname
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here
BLOB_ACCESS=private
UPSTASH_REDIS_REST_URL=https://your-upstash-url
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# Document parser mode:
# auto  = use MinerU when MINERU_API_TOKEN exists, otherwise use lightweight local parser
# local = force local parser for selectable-text PDF/HTML/TXT/Markdown
# mineru = force MinerU cloud parser
PARSER_MODE=auto

# MinerU cloud API (required for document parsing)
MINERU_API_TOKEN=your_mineru_api_token_here
MINERU_BASE_URL=https://mineru.net/api/v4
MINERU_MODEL_VERSION=pipeline
MINERU_POLL_INTERVAL_SECONDS=5
MINERU_MAX_POLLS=120
MINERU_DOWNLOAD_RETRIES=3
