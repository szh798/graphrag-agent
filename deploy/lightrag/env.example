# This file is an inventory only. Put real values in Vercel/Railway secrets.
# Never copy credentials into this repository.

# Shared release contract
LIGHTRAG_ENABLED=false
LIGHTRAG_VERSION=1.5.4
LIGHTRAG_STRICT_VERSION=true
LIGHTRAG_DEFAULT_MODE=mix
LIGHTRAG_MAX_GRAPH_NODES=200
LIGHTRAG_MAX_GRAPH_EDGES=2000
LIGHTRAG_EXPORT_MAX_NODES=10000
LIGHTRAG_EXPORT_MAX_EDGES=100000

# Vercel public gateway only (do not put database credentials in Vercel)
LIGHTRAG_TRANSPORT=remote
LIGHTRAG_BASE_URL=https://replace.up.railway.app
LIGHTRAG_HMAC_SECRET=replace-in-secret-manager
LIGHTRAG_HMAC_MAX_AGE_SECONDS=300
LIGHTRAG_REQUIRE_DISTRIBUTED_NONCE=true
LIGHTRAG_BACKFILL_ON_START=false
LIGHTRAG_BACKFILL_ALL_TENANTS_ACK=
LIGHTRAG_BACKFILL_RELEASE_ID=initial-v1
LIGHTRAG_BACKFILL_BATCH_SIZE=25
LIGHTRAG_BACKFILL_INTERVAL_SECONDS=300
LIGHTRAG_BACKFILL_INCLUDE_FAILED=false
LIGHTRAG_BACKFILL_FORCE=false
LIGHTRAG_NONCE_REDIS_REST_URL=https://replace.upstash.io
LIGHTRAG_NONCE_REDIS_REST_TOKEN=replace-in-secret-manager
LIGHTRAG_NONCE_KEY_PREFIX=graphrag:lightrag:nonce
LIGHTRAG_NONCE_TIMEOUT_SECONDS=5
LIGHTRAG_TIMEOUT_SECONDS=300

# Railway API and worker only
# Set LIGHTRAG_TRANSPORT=local in both Railway services. They share the same
# image and storage, while only the worker consumes the indexing queue.
# LIGHTRAG_TRANSPORT=local
LIGHTRAG_WORKSPACE_SECRET=replace-in-secret-manager
LIGHTRAG_WORKING_DIR=/var/lib/lightrag/rag_storage
LIGHTRAG_WORKSPACE_CACHE_MAX=64
LIGHTRAG_WORKSPACE_CACHE_TTL_SECONDS=1800
LIGHTRAG_HEALTH_PROBE_TIMEOUT_SECONDS=5
LIGHTRAG_HEALTH_PROBE_TTL_SECONDS=300
LIGHTRAG_REQUIRE_DURABLE_QUEUE=true
WORKING_DIR=/var/lib/lightrag/rag_storage
INPUT_DIR=/var/lib/lightrag/inputs
LOG_DIR=/var/log/lightrag
HOST=0.0.0.0
PORT=8000
WORKERS=2
TIMEOUT=300
MAX_PARALLEL_INSERT=2
MAX_ASYNC_LLM=4
SUMMARY_LANGUAGE=Chinese
ENTITY_EXTRACTION_USE_JSON=true
LIGHTRAG_PARSER=*:legacy-R

# Optional defense in depth for direct LightRAG Server routes. HMAC remains
# mandatory on the GraphRAG Studio bridge routes.
LIGHTRAG_API_KEY=replace-in-secret-manager

# Dedicated Neon retrieval database (Railway only)
LIGHTRAG_KV_STORAGE=PGKVStorage
LIGHTRAG_DOC_STATUS_STORAGE=PGDocStatusStorage
LIGHTRAG_VECTOR_STORAGE=PGVectorStorage
POSTGRES_HOST=replace.neon.tech
POSTGRES_PORT=5432
POSTGRES_USER=replace
POSTGRES_PASSWORD=replace-in-secret-manager
POSTGRES_DATABASE=replace
POSTGRES_MAX_CONNECTIONS=20
POSTGRES_SSL_MODE=require
POSTGRES_VECTOR_INDEX_TYPE=HNSW

# Dedicated Neo4j Aura database (Railway only)
LIGHTRAG_GRAPH_STORAGE=Neo4JStorage
NEO4J_URI=neo4j+s://replace.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=replace-in-secret-manager
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_POOL_SIZE=50

# Existing OpenAI-compatible GLM endpoint (Railway only). The integration
# deliberately reuses GraphRAG Studio's provider contract.
LLM_PROVIDER=zhipu
LLM_API_KEY=replace-in-secret-manager
LLM_BASE_URL=https://replace.example.com/v1
LLM_MODEL=replace-query-model
LLM_INDEX_MODEL=replace-extraction-model
LIGHTRAG_INDEX_MODEL=replace-extraction-model
LIGHTRAG_SUMMARY_LANGUAGE=Chinese
LLM_EMBEDDING_MODEL=replace-embedding-model
LLM_EMBEDDING_DIMENSIONS=1024

# BAAI/bge-reranker-v2-m3 through a Cohere-compatible endpoint
RERANK_BINDING=cohere
RERANK_MODEL=BAAI/bge-reranker-v2-m3
LIGHTRAG_RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_BINDING_HOST=https://replace.example.com/rerank
RERANK_BINDING_API_KEY=replace-in-secret-manager
RERANK_BY_DEFAULT=true

# Durable queue connectivity is shared so both Railway services expose a real
# readiness probe. Only the Worker consumes or acknowledges indexing jobs.
GRAPHRAG_QUEUE_BACKEND=upstash
UPSTASH_REDIS_REST_URL=https://replace.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace-in-secret-manager
INDEX_QUEUE_KEY=graphrag:index:queue
INDEX_PROCESSING_KEY=graphrag:index:queue:processing
INDEX_JOB_LEASE_SECONDS=330
INDEX_OWNER_LOCK_SECONDS=660
INDEX_WORKER_HEARTBEAT_KEY=graphrag:index:queue:worker-heartbeat
INDEX_WORKER_HEARTBEAT_TTL_SECONDS=120
INDEX_WORKER_HEARTBEAT_INTERVAL_SECONDS=40
# Optional; Railway's replica ID is used when this is blank.
INDEX_WORKER_ID=

# Gateway business data and Blob access (Railway Worker only)
GRAPHRAG_APP_BACKEND=postgres
DATABASE_URL=postgresql://replace-in-secret-manager
# Keep the classic graph in the business Postgres database. Do not set this to
# neo4j here: the NEO4J_* variables above are reserved for LightRAG Aura.
GRAPHRAG_GRAPH_BACKEND=postgres
GRAPHRAG_BLOB_BACKEND=vercel_blob
BLOB_READ_WRITE_TOKEN=replace-in-secret-manager
